# CodeSentinel configuration. Copy to .env and fill what you have.
# Any credential left blank causes that integration to run in deterministic
# MOCK mode, so the full pipeline still runs end-to-end with zero keys.

# --- GitHub (PRs/issues; blank => mock, no real PRs created) ---
GITHUB_TOKEN=

# --- LLM: Nvidia NIM (OpenAI-compatible; blank => mock heuristic analyst) ---
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-70b-instruct

# --- Embeddings fallback chain (all blank => local Ollama, then MiniLM/mock) ---
JINA_API_KEY=
GEMINI_API_KEY=

# --- Code sandbox: E2B (blank => mock local validator) ---
E2B_API_KEY=

# --- Local services (provisioned via Docker/Ollama) ---
OLLAMA_HOST=http://localhost:11434
QDRANT_HOST=localhost
QDRANT_PORT=6334
EMBED_MODEL=nomic-embed-text

# --- Tunables (defaults match the design document) ---
MAX_RPM=35
MAX_FILES=50
ANALYST_PARALLEL=10
FIX_CANDIDATES=3
CONFIDENCE_GATE=0.80
LOCALIZE_FALLBACK=0.50
SANDBOX_TIMEOUT=60
DASHBOARD_PORT=8080

# --- Behavior flags ---
# FORCE_MOCK=true forces every integration to mock regardless of keys.
FORCE_MOCK=false
NO_DASHBOARD=false
